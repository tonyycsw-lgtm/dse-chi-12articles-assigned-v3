  "article": {
    "title": "出師表\n(全文)",
    "paragraphs": [
      {
        "slices": [
          {
            "text": "先帝創業未半，",
            "translation": "先帝創立統一大業還未完成一半，",
            "vocabIds": [1, 2, 3],
            "audio": "./audio/audio_出師表/para1_001.mp3"
          },
          {
            "text": "而中道崩殂，",
            "translation": "卻中途去世了。",
            "vocabIds": [4, 5, 6],
            "audio": "./audio/audio_出師表/para1_002.mp3"
          },
          {
            "text": "今天下三分，",
            "translation": "現在天下分成三國，",
            "vocabIds": [7, 8, 9],
            "audio": "./audio/audio_出師表/para1_003.mp3"
          },
          {
            "text": "益州疲弊，",
            "translation": "我們益州地區民生睏乏，",
            "vocabIds": [10, 11],
            "audio": "./audio/audio_出師表/para1_004.mp3"
          },
          {
            "text": "此誠危急存亡之秋也。",
            "translation": "這確實是關係到國家危急存亡的關鍵時刻啊。",
            "vocabIds": [12, 13, 14, 15],
            "audio": "./audio/audio_出師表/para1_005.mp3"
          },
          {
            "text": "然侍衛之臣，",
            "translation": "然而，在宮廷內侍奉護衛的臣子們，",
            "vocabIds": [16, 17],
            "audio": "./audio/audio_出師表/para1_006.mp3"
          },
          {
            "text": "不懈於內；",
            "translation": "在朝廷內毫不懈怠；",
            "vocabIds": [18, 19, 20],
            "audio": "./audio/audio_出師表/para1_007.mp3"
          },
          {
            "text": "忠志之士，",
            "translation": "忠誠有志的將士們，",
            "vocabIds": [21],
            "audio": "./audio/audio_出師表/para1_008.mp3"
          },
          {
            "text": "忘身於外者，",
            "translation": "在疆場上奮不顧身的原因，",
            "vocabIds": [22, 19, 23, 24],
            "audio": "./audio/audio_出師表/para1_009.mp3"
          },
          {
            "text": "蓋追先帝之殊遇，",
            "translation": "都是因為追念先帝對他們的特殊恩遇，",
            "vocabIds": [25, 26, 1, 27, 28],
            "audio": "./audio/audio_出師表/para1_010.mp3"
          },
          {
            "text": "欲報之於陛下也。",
            "translation": "想要將這份恩情報答在陛下您身上啊。",
            "vocabIds": [29, 30, 27, 19, 31],
            "audio": "./audio/audio_出師表/para1_011.mp3"
          }
        ],
        "implication": {
          "summary": "分析當前嚴峻形勢，說明先帝恩澤深厚，群臣盡忠，為後文勸諫劉禪奠定基礎。",
          "paraphrase": "換句話說：現在國家處境很危險，先帝去世了，天下三分，我們蜀漢最弱。但好在官員和將士們因為感念先帝的恩情，都很拼命工作，想報答給您。",
          "grammar": {
            "display": "📌 修辭手法分析（第一段）\n\n1️⃣ 對比\n• 「先帝創業未半，而中道崩殂」 vs 「然侍衛之臣……忠志之士……」：先帝去世的遺憾與群臣奮發的現狀形成對比，突顯忠誠的可貴。\n\n2️⃣ 比喻\n• 「危急存亡之秋」：用「秋天」比喻關係成敗的關鍵時刻，形象表達處境的嚴峻。",
            "techniques": [
              {
                "type": "對比",
                "example": "「先帝創業未半，而中道崩殂」對比「然侍衛之臣，不懈於內；忠志之士，忘身於外」",
                "effect": "先帝壯志未酬與群臣盡忠職守形成對比，既表達遺憾，又彰顯群臣報恩之心"
              },
              {
                "type": "比喻",
                "example": "「危急存亡之秋」",
                "effect": "以「秋」喻關鍵時刻，形象生動地強調形勢的嚴峻"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "誠宜開張聖聽，",
            "translation": "陛下確實應該廣泛聽取群臣的意見，",
            "vocabIds": [13, 32, 33],
            "audio": "./audio/audio_出師表/para2_001.mp3"
          },
          {
            "text": "以光先帝遺德，",
            "translation": "來發揚光大先帝遺留下來的美德，",
            "vocabIds": [34, 35, 1, 36],
            "audio": "./audio/audio_出師表/para2_002.mp3"
          },
          {
            "text": "恢弘志士之氣；",
            "translation": "振奮有志之士的士氣；",
            "vocabIds": [37, 38, 27, 39],
            "audio": "./audio/audio_出師表/para2_003.mp3"
          },
          {
            "text": "不宜妄自菲薄，",
            "translation": "不應該隨便看輕自己，",
            "vocabIds": [40, 41],
            "audio": "./audio/audio_出師表/para2_004.mp3"
          },
          {
            "text": "引喻失義，",
            "translation": "說話不恰當而失去大義，",
            "vocabIds": [42, 43],
            "audio": "./audio/audio_出師表/para2_005.mp3"
          },
          {
            "text": "以塞忠諫之路也。",
            "translation": "以致堵塞了忠臣進諫的道路。",
            "vocabIds": [34, 44, 45, 27, 46],
            "audio": "./audio/audio_出師表/para2_006.mp3"
          }
        ],
        "implication": {
          "summary": "勸諫劉禪要廣開言路，發揚先帝美德，不可妄自菲薄。",
          "paraphrase": "換句話說：您一定要多聽取意見，發揚先帝的好傳統，提振士氣。千萬別自卑，講話沒分寸，堵住了別人進諫的路。",
          "grammar": {
            "display": "📌 修辭手法分析（第二段）\n\n1️⃣ 對比\n• 「宜……」與「不宜……」形成正反對比，鮮明指出應該做和不應該做的事。",
            "techniques": [
              {
                "type": "對比",
                "example": "「誠宜開張聖聽……恢弘志士之氣」與「不宜妄自菲薄……以塞忠諫之路也」",
                "effect": "通過正反對比，強化勸諫效果，使論點更加鮮明有力"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "宮中、府中，",
            "translation": "皇宮中和丞相府中，",
            "vocabIds": [47, 48],
            "audio": "./audio/audio_出師表/para3_001.mp3"
          },
          {
            "text": "俱為一體，",
            "translation": "都是一個整體，",
            "vocabIds": [49, 50, 51],
            "audio": "./audio/audio_出師表/para3_002.mp3"
          },
          {
            "text": "陟罰臧否，",
            "translation": "晉升懲罰，表揚批評，",
            "vocabIds": [52, 53, 54],
            "audio": "./audio/audio_出師表/para3_003.mp3"
          },
          {
            "text": "不宜異同。",
            "translation": "不應該有所不同。",
            "vocabIds": [40, 55],
            "audio": "./audio/audio_出師表/para3_004.mp3"
          },
          {
            "text": "若有作姦犯科，",
            "translation": "如果有做壞事、違犯法令的，",
            "vocabIds": [56, 57, 58],
            "audio": "./audio/audio_出師表/para3_005.mp3"
          },
          {
            "text": "及為忠善者，",
            "translation": "以及行為忠誠善良的人，",
            "vocabIds": [59, 50, 60, 24],
            "audio": "./audio/audio_出師表/para3_006.mp3"
          },
          {
            "text": "宜付有司，",
            "translation": "都應該交給主管的官員，",
            "vocabIds": [32, 61, 62],
            "audio": "./audio/audio_出師表/para3_007.mp3"
          },
          {
            "text": "論其刑賞，",
            "translation": "判定他們該受罰還是該受賞，",
            "vocabIds": [63, 64, 65],
            "audio": "./audio/audio_出師表/para3_008.mp3"
          },
          {
            "text": "以昭陛下平明之治；",
            "translation": "以彰顯陛下公平清明的治理；",
            "vocabIds": [34, 66, 31, 67, 27, 68],
            "audio": "./audio/audio_出師表/para3_009.mp3"
          },
          {
            "text": "不宜偏私，",
            "translation": "不應該偏袒徇私，",
            "vocabIds": [40, 69],
            "audio": "./audio/audio_出師表/para3_010.mp3"
          },
          {
            "text": "使內外異法也。",
            "translation": "使得宮內和宮外的法令有所不同。",
            "vocabIds": [70, 71, 72],
            "audio": "./audio/audio_出師表/para3_011.mp3"
          }
        ],
        "implication": {
          "summary": "強調執法必須公平一致，宮中府中應賞罰分明，不可偏私。",
          "paraphrase": "換句話說：皇宮裡和朝廷各部門都是一家人，獎罰表揚都要一個標準。無論好壞，都交給專人處理，這樣才能顯示您的公正。千萬別偏心，搞得內外兩個法。",
          "grammar": {
            "display": "📌 修辭手法分析（第三段）\n\n1️⃣ 對比\n• 「若有作姦犯科」與「及為忠善者」：奸邪與忠善的對比，引出下文應公平賞罰的觀點。",
            "techniques": [
              {
                "type": "對比",
                "example": "「若有作姦犯科」與「及為忠善者」",
                "effect": "善惡對舉，為後文「論其刑賞」提供依據，強調賞罰分明的重要性"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "侍中、侍郎郭攸之、費禕、董允等，",
            "translation": "侍中、侍郎郭攸之、費禕、董允等人，",
            "vocabIds": [73, 74, 75, 76, 77, 78],
            "audio": "./audio/audio_出師表/para4_001.mp3"
          },
          {
            "text": "此皆良實，",
            "translation": "這些都是善良誠實的人，",
            "vocabIds": [12, 79, 80],
            "audio": "./audio/audio_出師表/para4_002.mp3"
          },
          {
            "text": "志慮忠純，",
            "translation": "志向和心思忠誠純正，",
            "vocabIds": [81, 82],
            "audio": "./audio/audio_出師表/para4_003.mp3"
          },
          {
            "text": "是以先帝簡拔以遺陛下。",
            "translation": "所以先帝選拔出來留給陛下任用。",
            "vocabIds": [83, 1, 84, 34, 85, 31],
            "audio": "./audio/audio_出師表/para4_004.mp3"
          },
          {
            "text": "愚以為宮中之事，",
            "translation": "我認為宮裡的事情，",
            "vocabIds": [86, 87, 47, 27, 88],
            "audio": "./audio/audio_出師表/para4_005.mp3"
          },
          {
            "text": "事無大小，",
            "translation": "事情無論大小，",
            "vocabIds": [88, 89, 90],
            "audio": "./audio/audio_出師表/para4_006.mp3"
          },
          {
            "text": "悉以咨之，",
            "translation": "都拿來詢問他們的意見，",
            "vocabIds": [91, 34, 92, 27],
            "audio": "./audio/audio_出師表/para4_007.mp3"
          },
          {
            "text": "然後施行，",
            "translation": "然後再去實行，",
            "vocabIds": [93, 94],
            "audio": "./audio/audio_出師表/para4_008.mp3"
          },
          {
            "text": "必能裨補闕漏，",
            "translation": "一定能彌補缺點和疏漏，",
            "vocabIds": [95, 96, 97],
            "audio": "./audio/audio_出師表/para4_009.mp3"
          },
          {
            "text": "有所廣益。",
            "translation": "獲得更多的好處。",
            "vocabIds": [57, 98, 99],
            "audio": "./audio/audio_出師表/para4_010.mp3"
          },
          {
            "text": "將軍向寵，",
            "translation": "將軍向寵，",
            "vocabIds": [100, 101],
            "audio": "./audio/audio_出師表/para4_011.mp3"
          },
          {
            "text": "性行淑均，",
            "translation": "性情品德善良平和，",
            "vocabIds": [102, 103],
            "audio": "./audio/audio_出師表/para4_012.mp3"
          },
          {
            "text": "曉暢軍事，",
            "translation": "通曉熟悉軍事，",
            "vocabIds": [104, 105],
            "audio": "./audio/audio_出師表/para4_013.mp3"
          },
          {
            "text": "試用於昔日，",
            "translation": "從前試用過他，",
            "vocabIds": [106, 19, 107],
            "audio": "./audio/audio_出師表/para4_014.mp3"
          },
          {
            "text": "先帝稱之曰「能」，",
            "translation": "先帝稱讚他能幹，",
            "vocabIds": [1, 108, 27, 109, 96],
            "audio": "./audio/audio_出師表/para4_015.mp3"
          },
          {
            "text": "是以眾議舉寵為督。",
            "translation": "所以大家商議推舉向寵做都督。",
            "vocabIds": [83, 110, 111, 101, 50, 112],
            "audio": "./audio/audio_出師表/para4_016.mp3"
          },
          {
            "text": "愚以為營中之事，",
            "translation": "我認為軍營裡的事情，",
            "vocabIds": [86, 87, 113, 27, 88],
            "audio": "./audio/audio_出師表/para4_017.mp3"
          },
          {
            "text": "悉以咨之，",
            "translation": "都拿來詢問他的意見，",
            "vocabIds": [91, 34, 92, 27],
            "audio": "./audio/audio_出師表/para4_018.mp3"
          },
          {
            "text": "必能使行陣和睦，",
            "translation": "一定能夠使軍隊內部團結和睦，",
            "vocabIds": [95, 96, 70, 114, 115],
            "audio": "./audio/audio_出師表/para4_019.mp3"
          },
          {
            "text": "優劣得所。",
            "translation": "才能高低不同的將士都能得到合適的安排。",
            "vocabIds": [116, 117, 98],
            "audio": "./audio/audio_出師表/para4_020.mp3"
          }
        ],
        "implication": {
          "summary": "向劉禪推薦宮中與軍中可信任的賢臣，強調諮詢他們的意見對國家有益。",
          "paraphrase": "換句話說：我給您推薦幾個人。宮裡的郭攸之他們都是先帝挑選的好人，您有事多問問他們再辦，準能查漏補缺。軍中的向寵也不錯，大家都推舉他，軍隊的事問他準能辦好。",
          "grammar": {
            "display": "📌 修辭手法分析（第四段）\n\n1️⃣ 引用\n• 「先帝稱之曰『能』」：引用先帝的評價，增強推薦向寵的說服力和權威性。",
            "techniques": [
              {
                "type": "引用",
                "example": "「先帝稱之曰『能』」",
                "effect": "引用先帝的讚譽，為向寵的能力提供權威背書，使推薦更具說服力"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "親賢臣，",
            "translation": "親近賢臣，",
            "vocabIds": [118, 119],
            "audio": "./audio/audio_出師表/para5_001.mp3"
          },
          {
            "text": "遠小人，",
            "translation": "疏遠小人，",
            "vocabIds": [120, 121],
            "audio": "./audio/audio_出師表/para5_002.mp3"
          },
          {
            "text": "此先漢所以興隆也；",
            "translation": "這是前漢能夠興盛的原因；",
            "vocabIds": [12, 122, 123, 124],
            "audio": "./audio/audio_出師表/para5_003.mp3"
          },
          {
            "text": "親小人，",
            "translation": "親近小人，",
            "vocabIds": [118, 121],
            "audio": "./audio/audio_出師表/para5_004.mp3"
          },
          {
            "text": "遠賢臣，",
            "translation": "疏遠賢臣，",
            "vocabIds": [120, 119],
            "audio": "./audio/audio_出師表/para5_005.mp3"
          },
          {
            "text": "此後漢所以傾頹也。",
            "translation": "這是後漢衰敗的原因。",
            "vocabIds": [12, 125, 123, 126],
            "audio": "./audio/audio_出師表/para5_006.mp3"
          },
          {
            "text": "先帝在時，",
            "translation": "先帝在世的時候，",
            "vocabIds": [1, 127, 128],
            "audio": "./audio/audio_出師表/para5_007.mp3"
          },
          {
            "text": "每與臣論此事，",
            "translation": "每次和我談論這些事，",
            "vocabIds": [129, 130, 131, 63, 12, 88],
            "audio": "./audio/audio_出師表/para5_008.mp3"
          },
          {
            "text": "未嘗不嘆息痛恨於桓、靈也！",
            "translation": "沒有不對桓帝、靈帝的作為感嘆痛恨的！",
            "vocabIds": [132, 133, 134, 135, 19, 136, 137],
            "audio": "./audio/audio_出師表/para5_009.mp3"
          },
          {
            "text": "侍中、尚書、長史、參軍，",
            "translation": "侍中、尚書、長史、參軍，",
            "vocabIds": [73, 138, 139, 140],
            "audio": "./audio/audio_出師表/para5_010.mp3"
          },
          {
            "text": "此悉貞良死節之臣，",
            "translation": "這些都是堅貞可靠、能以死報國的臣子，",
            "vocabIds": [12, 91, 141, 142, 27, 131],
            "audio": "./audio/audio_出師表/para5_011.mp3"
          },
          {
            "text": "願陛下親之、信之，",
            "translation": "希望陛下親近他們、信任他們，",
            "vocabIds": [143, 31, 118, 27, 144, 27],
            "audio": "./audio/audio_出師表/para5_012.mp3"
          },
          {
            "text": "則漢室之隆，",
            "translation": "那麼漢室的興隆，",
            "vocabIds": [145, 146, 27, 147],
            "audio": "./audio/audio_出師表/para5_013.mp3"
          },
          {
            "text": "可計日而待也。",
            "translation": "就可以數著日子等到了。",
            "vocabIds": [148, 149, 4, 150],
            "audio": "./audio/audio_出師表/para5_014.mp3"
          }
        ],
        "implication": {
          "summary": "以歷史教訓告誡劉禪，親賢臣、遠小人乃國家興衰關鍵，並再次叮囑要信任所薦賢臣。",
