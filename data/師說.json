    "paragraphs": [
      {
        "slices": [
          {
            "text": "古之學者必有師。",
            "translation": "古時候求學的人一定有老師。",
            "vocabIds": [1, 2, 3, 4, 5],
            "audio": "./audio/audio_師說/para1_001.mp3"
          },
          {
            "text": "師者，",
            "translation": "老師，",
            "vocabIds": [6, 7],
            "audio": "./audio/audio_師說/para1_002.mp3"
          },
          {
            "text": "所以傳道、受業、解惑也。",
            "translation": "是靠他來傳授道理、教導學業、解答疑惑的人。",
            "vocabIds": [8, 9, 10, 11, 12, 13, 14],
            "audio": "./audio/audio_師說/para1_003.mp3"
          },
          {
            "text": "人非生而知之者，",
            "translation": "人不是一生下來就懂得道理的，",
            "vocabIds": [15, 16, 17, 18, 19, 20],
            "audio": "./audio/audio_師說/para1_004.mp3"
          },
          {
            "text": "孰能無惑？",
            "translation": "誰能沒有疑惑？",
            "vocabIds": [21, 22, 23],
            "audio": "./audio/audio_師說/para1_005.mp3"
          },
          {
            "text": "惑而不從師，",
            "translation": "有了疑惑卻不跟從老師學習，",
            "vocabIds": [23, 24, 25, 6],
            "audio": "./audio/audio_師說/para1_006.mp3"
          },
          {
            "text": "其為惑也終不解矣。",
            "translation": "那些疑惑就始終不能解開啊。",
            "vocabIds": [26, 27, 23, 28, 29, 30],
            "audio": "./audio/audio_師說/para1_007.mp3"
          }
        ],
        "implication": {
          "summary": "開宗明義，提出「古之學者必有師」的中心論點，並闡明老師的職責是「傳道、受業、解惑」。",
          "paraphrase": "換句話說：古人學習都離不開老師，因為老師就是教道理、教知識、解答疑惑的人。沒有人天生什麼都懂，有疑惑就得問老師，不然永遠搞不明白。",
          "grammar": {
            "display": "📌 修辭手法分析（第一段）\n\n1️⃣ 判斷句\n• 「師者，所以傳道、受業、解惑也」：典型的判斷句式，明確老師的定義。\n\n2️⃣ 反問句\n• 「孰能無惑？」：以反問強調人人皆有疑惑，增強說服力。",
            "techniques": [
              {
                "type": "判斷句",
                "example": "「師者，所以傳道、受業、解惑也」",
                "effect": "用判斷句式給老師下定義，觀點明確，論證有力"
              },
              {
                "type": "反問",
                "example": "「孰能無惑？」",
                "effect": "以反問強調人皆有惑，自然引出從師的必要性，語氣強烈"
              }
            ]
          }
        }
      },
      {
