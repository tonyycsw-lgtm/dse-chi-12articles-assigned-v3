  "article": {
    "title": "岳陽樓記\n(全文)",
    "paragraphs": [
      {
        "slices": [
          {
            "text": "慶曆四年春，",
            "translation": "慶曆四年的春天，",
            "vocabIds": [1, 2],
            "audio": "./audio/audio_岳陽樓記/para1_001.mp3"
          },
          {
            "text": "滕子京謫守巴陵郡。",
            "translation": "滕子京被貶謫，擔任巴陵郡的太守。",
            "vocabIds": [3, 4, 5, 6],
            "audio": "./audio/audio_岳陽樓記/para1_002.mp3"
          },
          {
            "text": "越明年，",
            "translation": "到了第二年，",
            "vocabIds": [7, 8],
            "audio": "./audio/audio_岳陽樓記/para1_003.mp3"
          },
          {
            "text": "政通人和，",
            "translation": "政事通達，百姓和樂，",
            "vocabIds": [9, 10],
            "audio": "./audio/audio_岳陽樓記/para1_004.mp3"
          },
          {
            "text": "百廢具興。",
            "translation": "各種荒廢的事業都興辦起來了。",
            "vocabIds": [11],
            "audio": "./audio/audio_岳陽樓記/para1_005.mp3"
          },
          {
            "text": "乃重修岳陽樓，",
            "translation": "於是重新修建岳陽樓，",
            "vocabIds": [12, 13, 14],
            "audio": "./audio/audio_岳陽樓記/para1_006.mp3"
          },
          {
            "text": "增其舊制，",
            "translation": "擴大它原有的規模，",
            "vocabIds": [15, 16, 17],
            "audio": "./audio/audio_岳陽樓記/para1_007.mp3"
          },
          {
            "text": "刻唐賢、今人詩賦於其上；",
            "translation": "把唐代名家和當代人的詩賦刻在它的上面；",
            "vocabIds": [18, 19, 20, 21, 22, 23],
            "audio": "./audio/audio_岳陽樓記/para1_008.mp3"
          },
          {
            "text": "屬予作文以記之。",
            "translation": "囑託我寫一篇文章來記述這件事。",
            "vocabIds": [24, 25, 26, 27, 28, 29],
            "audio": "./audio/audio_岳陽樓記/para1_009.mp3"
          }
        ],
        "implication": {
          "summary": "記敘重修岳陽樓的緣由，並點明寫作本文的起因。",
          "paraphrase": "換句話說：滕子京被貶到巴陵郡，但政績很好，於是重修了岳陽樓，還讓我寫篇文章記錄下來。",
          "grammar": {
            "display": "📌 修辭手法分析（第一段）\n\n1️⃣ 對偶\n• 「政通人和」：政事通達與百姓和樂形成對偶，簡潔地概括了良好的治理局面。",
            "techniques": [
              {
                "type": "對偶",
                "example": "「政通人和」",
                "effect": "以簡潔的詞語概括了政治清明、百姓和樂的景象，為下文重修岳陽樓提供了背景。"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "予觀夫巴陵勝狀，",
            "translation": "我看那巴陵地區的美好景色，",
            "vocabIds": [25, 30, 31, 32, 33],
            "audio": "./audio/audio_岳陽樓記/para2_001.mp3"
          },
          {
            "text": "在洞庭一湖。",
            "translation": "全集中在一個洞庭湖上。",
            "vocabIds": [34, 35, 36, 37],
            "audio": "./audio/audio_岳陽樓記/para2_002.mp3"
          },
          {
            "text": "銜遠山，",
            "translation": "它含著遠處的山峰，",
            "vocabIds": [38, 39],
            "audio": "./audio/audio_岳陽樓記/para2_003.mp3"
          },
          {
            "text": "吞長江，",
            "translation": "吞吐著長江的水流，",
            "vocabIds": [40, 41],
            "audio": "./audio/audio_岳陽樓記/para2_004.mp3"
          },
          {
            "text": "浩浩湯湯，",
            "translation": "水勢浩大，波濤洶湧，",
            "vocabIds": [42],
            "audio": "./audio/audio_岳陽樓記/para2_005.mp3"
          },
          {
            "text": "橫無際涯；",
            "translation": "寬廣得沒有邊際；",
            "vocabIds": [43, 44, 45],
            "audio": "./audio/audio_岳陽樓記/para2_006.mp3"
          },
          {
            "text": "朝暉夕陰，",
            "translation": "早晨陽光照耀，傍晚光線昏暗，",
            "vocabIds": [46, 47, 48, 49],
            "audio": "./audio/audio_岳陽樓記/para2_007.mp3"
          },
          {
            "text": "氣象萬千。",
            "translation": "景象變化萬千。",
            "vocabIds": [50, 51],
            "audio": "./audio/audio_岳陽樓記/para2_008.mp3"
          },
          {
            "text": "此則岳陽樓之大觀也，",
            "translation": "這就是在岳陽樓上所見到的雄偉景象啊，",
            "vocabIds": [52, 53, 14, 54, 55, 56],
            "audio": "./audio/audio_岳陽樓記/para2_009.mp3"
          },
          {
            "text": "前人之述備矣。",
            "translation": "前人的記述已經很詳盡了。",
            "vocabIds": [57, 54, 58, 59, 60],
            "audio": "./audio/audio_岳陽樓記/para2_010.mp3"
          },
          {
            "text": "然則北通巫峽，",
            "translation": "既然如此，那麼這裡向北可以通到巫峽，",
            "vocabIds": [61, 62, 63, 64],
            "audio": "./audio/audio_岳陽樓記/para2_011.mp3"
          },
          {
            "text": "南極瀟湘，",
            "translation": "向南直達瀟水、湘水，",
            "vocabIds": [65, 66, 67],
            "audio": "./audio/audio_岳陽樓記/para2_012.mp3"
          },
          {
            "text": "遷客騷人，",
            "translation": "被貶謫流遷的官員和詩人，",
            "vocabIds": [68, 69],
            "audio": "./audio/audio_岳陽樓記/para2_013.mp3"
          },
          {
            "text": "多會於此，",
            "translation": "大多在這裡聚會，",
            "vocabIds": [70, 71, 22, 52],
            "audio": "./audio/audio_岳陽樓記/para2_014.mp3"
          },
          {
            "text": "覽物之情，",
            "translation": "他們觀賞景物時的心情，",
            "vocabIds": [72, 73, 54, 74],
            "audio": "./audio/audio_岳陽樓記/para2_015.mp3"
          },
          {
            "text": "得無異乎？",
            "translation": "能夠沒有差別嗎？",
            "vocabIds": [75, 76, 77],
            "audio": "./audio/audio_岳陽樓記/para2_016.mp3"
          }
        ],
        "implication": {
          "summary": "描寫洞庭湖的宏偉氣勢，並引出「遷客騷人」因景生情、心境各異的觀點。",
          "paraphrase": "換句話說：洞庭湖景色壯闊，氣象萬千，前人寫了很多。但這裡是交通要道，很多被貶的官員和詩人在此聚會，他們看到這景色，心情應該會不一樣吧？",
          "grammar": {
            "display": "📌 修辭手法分析（第二段）\n\n1️⃣ 擬人\n• 「銜遠山，吞長江」：用「銜」、「吞」這兩個人的動作來描寫洞庭湖，生動地表現出湖水的浩渺和氣勢。\n\n2️⃣ 對偶\n• 「朝暉夕陰」：早晨的陽光與傍晚的陰暗形成對偶，概括了洞庭湖一天之中光線的變化。\n\n3️⃣ 反問\n• 「得無異乎？」：用反問的語氣，強調了遷客騷人因景生情必定會有所不同，引出下文。",
            "techniques": [
              {
                "type": "擬人",
                "example": "「銜遠山，吞長江」",
                "effect": "賦予洞庭湖人的動作，形象地寫出了湖水的廣闊和包容萬物的氣勢。"
              },
              {
                "type": "對偶",
                "example": "「朝暉夕陰」",
                "effect": "以簡潔的對比，寫出了洞庭湖從早到晚的光影變化，為後文「氣象萬千」作鋪墊。"
              },
              {
                "type": "反問",
                "example": "「得無異乎？」",
                "effect": "用反問句加強語氣，引發讀者思考，並自然地過渡到下文對兩種不同情境的描寫。"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "若夫霪雨霏霏，",
            "translation": "像那陰雨連綿不斷，",
            "vocabIds": [78, 79, 80],
            "audio": "./audio/audio_岳陽樓記/para3_001.mp3"
          },
          {
            "text": "連月不開；",
            "translation": "接連幾個月都不放晴；",
            "vocabIds": [81, 82, 44, 83],
            "audio": "./audio/audio_岳陽樓記/para3_002.mp3"
          },
          {
            "text": "陰風怒號，",
            "translation": "陰冷的風怒吼著，",
            "vocabIds": [84, 85],
            "audio": "./audio/audio_岳陽樓記/para3_003.mp3"
          },
          {
            "text": "濁浪排空；",
            "translation": "混濁的波浪沖向天空；",
            "vocabIds": [86, 87],
            "audio": "./audio/audio_岳陽樓記/para3_004.mp3"
          },
          {
            "text": "日星隱曜，",
            "translation": "太陽和星星隱藏了光輝，",
            "vocabIds": [88, 89, 90, 91],
            "audio": "./audio/audio_岳陽樓記/para3_005.mp3"
          },
          {
            "text": "山岳潛形；",
            "translation": "山岳也隱沒了形體；",
            "vocabIds": [92, 93, 94],
            "audio": "./audio/audio_岳陽樓記/para3_006.mp3"
          },
          {
            "text": "商旅不行，",
            "translation": "商人旅客無法通行，",
            "vocabIds": [95, 44, 96],
            "audio": "./audio/audio_岳陽樓記/para3_007.mp3"
          },
          {
            "text": "檣傾楫摧；",
            "translation": "船桅倒下，船槳折斷；",
            "vocabIds": [97, 98, 99, 100],
            "audio": "./audio/audio_岳陽樓記/para3_008.mp3"
          },
          {
            "text": "薄暮冥冥，",
            "translation": "傍晚時分天色昏暗，",
            "vocabIds": [101, 102],
            "audio": "./audio/audio_岳陽樓記/para3_009.mp3"
          },
          {
            "text": "虎嘯猿啼。",
            "translation": "傳來老虎的長嘯和猿猴的悲啼。",
            "vocabIds": [103, 104, 105, 106],
            "audio": "./audio/audio_岳陽樓記/para3_010.mp3"
          },
          {
            "text": "登斯樓也，",
            "translation": "這時登上這座樓，",
            "vocabIds": [107, 108, 109, 56],
            "audio": "./audio/audio_岳陽樓記/para3_011.mp3"
          },
          {
            "text": "則有去國懷鄉，",
            "translation": "就會產生離開國都、懷念家鄉，",
            "vocabIds": [53, 110, 111, 112],
            "audio": "./audio/audio_岳陽樓記/para3_012.mp3"
          },
          {
            "text": "憂讒畏譏，",
            "translation": "擔心遭到讒言誹謗、害怕受到譏諷嘲笑的情緒，",
            "vocabIds": [113, 114, 115, 116],
            "audio": "./audio/audio_岳陽樓記/para3_013.mp3"
          },
          {
            "text": "滿目蕭然，",
            "translation": "滿眼都是蕭條的景象，",
            "vocabIds": [117, 118],
            "audio": "./audio/audio_岳陽樓記/para3_014.mp3"
          },
          {
            "text": "感極而悲者矣。",
            "translation": "感慨到了極點而產生了悲傷的心情。",
            "vocabIds": [119, 120, 121, 122, 60],
            "audio": "./audio/audio_岳陽樓記/para3_015.mp3"
          }
        ],
        "implication": {
          "summary": "描寫在陰雨天氣登上岳陽樓所見的淒涼景象，以及由此引發的遷客騷人悲傷的心情。",
          "paraphrase": "換句話說：如果遇到天氣不好，連月下雨，風大浪高，日月無光，船也不能走。這時候登上岳陽樓，那些被貶官的人就會想起自己的遭遇，覺得前途渺茫，悲從中來。",
          "grammar": {
            "display": "📌 修辭手法分析（第三段）\n\n1️⃣ 排比\n• 「日星隱曜，山岳潛形；商旅不行，檣傾楫摧」：連用四個結構相似的句子，描繪了陰雨天氣下天地萬物的慘澹景象，增強了畫面的悲涼氣氛。\n\n2️⃣ 對偶\n• 「去國懷鄉，憂讒畏譏」：離開國都與懷念家鄉，擔憂讒言與害怕譏諷，兩兩對偶，細緻刻畫了遷客騷人複雜而沉痛的內心世界。",
            "techniques": [
              {
                "type": "排比",
                "example": "「日星隱曜，山岳潛形；商旅不行，檣傾楫摧」",
                "effect": "通過一系列並列的景象描寫，渲染出一種陰森、蕭條、充滿壓抑感的氛圍，為下文抒發悲情作了有力的鋪墊。"
              },
              {
                "type": "對偶",
                "example": "「去國懷鄉，憂讒畏譏」",
                "effect": "工整地寫出了被貶官員內心的兩種主要痛苦：對故鄉的思念和對政治迫害的恐懼，使情感表達更為深刻。"
              }
            ]
          }
        }
      },
      {
        "slices": [
          {
            "text": "至若春和景明，",
            "translation": "到了春風和煦、陽光明媚的時節，",
            "vocabIds": [123, 124, 125],
            "audio": "./audio/audio_岳陽樓記/para4_001.mp3"
          },
          {
            "text": "波瀾不驚，",
            "translation": "湖面風平浪靜，",
            "vocabIds": [126, 44, 127],
            "audio": "./audio/audio_岳陽樓記/para4_002.mp3"
          },
          {
            "text": "上下天光，",
            "translation": "天色與湖光上下相接，",
            "vocabIds": [128, 129],
            "audio": "./audio/audio_岳陽樓記/para4_003.mp3"
          },
          {
            "text": "一碧萬頃；",
            "translation": "一片碧綠，廣闊無邊；",
            "vocabIds": [130, 131],
            "audio": "./audio/audio_岳陽樓記/para4_004.mp3"
          },
          {
            "text": "沙鷗翔集，",
            "translation": "沙洲上的鷗鳥時而飛翔，時而停歇，",
            "vocabIds": [132, 133],
            "audio": "./audio/audio_岳陽樓記/para4_005.mp3"
          },
          {
            "text": "錦鱗游泳；",
            "translation": "美麗的魚兒游來游去；",
            "vocabIds": [134, 135],
            "audio": "./audio/audio_岳陽樓記/para4_006.mp3"
          },
          {
            "text": "岸芷汀蘭，",
            "translation": "岸上的香草，小洲上的蘭花，",
            "vocabIds": [136, 137],
            "audio": "./audio/audio_岳陽樓記/para4_007.mp3"
          },
          {
            "text": "郁郁青青。",
            "translation": "香氣濃郁，顏色青翠。",
            "vocabIds": [138, 139],
            "audio": "./audio/audio_岳陽樓記/para4_008.mp3"
          },
          {
            "text": "而或長煙一空，",
            "translation": "有時大片煙霧完全消散，",
            "vocabIds": [140, 141, 142],
            "audio": "./audio/audio_岳陽樓記/para4_009.mp3"
          },
          {
            "text": "皓月千里，",
            "translation": "皎潔的月光一瀉千里，",
            "vocabIds": [143, 144],
            "audio": "./audio/audio_岳陽樓記/para4_010.mp3"
          },
          {
            "text": "浮光躍金，",
            "translation": "浮動的月光像躍動的黃金，",
            "vocabIds": [145, 146],
            "audio": "./audio/audio_岳陽樓記/para4_011.mp3"
          },
          {
            "text": "靜影沉璧；",
            "translation": "靜靜的月影像沉入水中的玉璧；",
            "vocabIds": [147, 148],
            "audio": "./audio/audio_岳陽樓記/para4_012.mp3"
          },
          {
            "text": "漁歌互答，",
            "translation": "漁人的歌聲互相應和，",
            "vocabIds": [149, 150],
            "audio": "./audio/audio_岳陽樓記/para4_013.mp3"
          },
          {
            "text": "此樂何極！",
            "translation": "這種快樂真是無窮無盡啊！",
            "vocabIds": [52, 151, 152],
            "audio": "./audio/audio_岳陽樓記/para4_014.mp3"
          },
          {
            "text": "登斯樓也，",
            "translation": "這時登上這座樓，",
            "vocabIds": [107, 108, 109, 56],
            "audio": "./audio/audio_岳陽樓記/para4_015.mp3"
          },
          {
            "text": "則有心曠神怡，",
            "translation": "就會感到心胸開闊、精神愉快，",
            "vocabIds": [53, 110, 153],
            "audio": "./audio/audio_岳陽樓記/para4_016.mp3"
          },
          {
            "text": "寵辱偕忘，",
            "translation": "榮耀和屈辱都一併忘了，",
            "vocabIds": [154, 155, 156],
            "audio": "./audio/audio_岳陽樓記/para4_017.mp3"
          },
          {
            "text": "把酒臨風，",
            "translation": "端著酒杯，迎著清風，",
            "vocabIds": [157, 158],
            "audio": "./audio/audio_岳陽樓記/para4_018.mp3"
          },
          {
            "text": "其喜洋洋者矣。",
            "translation": "那真是高興得不得了啊。",
            "vocabIds": [159, 160, 122, 60],
            "audio": "./audio/audio_岳陽樓記/para4_019.mp3"
          }
        ],
        "implication": {
          "summary": "描寫在春和景明之時登上岳陽樓所見的明媚景象，以及由此引發的遷客騷人喜悅的心情。",
